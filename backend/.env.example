NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=happy_bonding
DB_USER=root
DB_PASSWORD=
DB_LOGGING=false

JWT_ACCESS_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=30d

CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@example.com

META_WEBHOOK_VERIFY_TOKEN=replace-with-your-webhook-verification-token
META_APP_SECRET=replace-with-your-meta-app-secret
